{
  "name": "knex-orm",
  "version": "1.0.0",
  "description": "ORM superset for Knex.js with decorators, NestJS and Bun support",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:node": "jest",
    "test:bun": "bun test"
  },
  "keywords": [
    "knex",
    "orm",
    "typescript",
    "decorators",
    "nestjs",
    "bun"
  ],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "knex": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "typescript": ">=4.5.0"
  },
  "devDependencies": {
    "knex": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "typescript": "^5.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "sqlite3": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
