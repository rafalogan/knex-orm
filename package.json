{
  "name": "knex-orm",
  "version": "1.0.0",
  "description": "ORM superset for Knex.js with decorators, NestJS and Bun support",
  "main": "./dist/index.js",
  "bin": {
    "kor": "./dist/cli/migrate-generate.js",
    "knex-orm": "./dist/cli/migrate-generate.js"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.js"
    },
    "./migration": {
      "types": "./dist/adapters/migration/index.d.ts",
      "import": "./dist/adapters/migration/index.js",
      "require": "./dist/adapters/migration/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "migrate:generate": "node dist/cli/migrate-generate.js migrate:generate",
    "migrate:run": "node dist/cli/migrate-generate.js migrate:run",
    "migrate:rollback": "node dist/cli/migrate-generate.js migrate:rollback",
    "connection:init": "node dist/cli/migrate-generate.js connection:init",
    "connection:test": "node dist/cli/migrate-generate.js connection:test",
    "connection:list": "node dist/cli/migrate-generate.js connection:list",
    "test": "jest",
    "test:node": "jest",
    "test:bun": "bun test",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check ."
  },
  "keywords": [
    "knex",
    "orm",
    "typescript",
    "decorators",
    "nestjs",
    "bun"
  ],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "knex": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "typescript": ">=4.5.0",
    "@nestjs/common": ">=9.0.0",
    "@nestjs/core": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "knex": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "typescript": "^5.0.0",
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.0.0",
    "eslint": "^10.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "globals": "^15.0.0",
    "typescript-eslint": "^8.0.0",
    "sqlite3": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
